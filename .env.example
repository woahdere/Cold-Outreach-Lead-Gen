# ─────────────────────────────────────────────────────────────
# Cold Outreach Lead Gen — environment template
# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Apify API token — runs the Google Maps scraper.
# Get it from: https://console.apify.com/  (Settings → Integrations → API token)
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google service-account key, as a SINGLE-LINE JSON string.
# This is the ENTIRE contents of the .json key file you downloaded, on one line.
# Tip: to flatten a key file to one line, run:  cat key.json | tr -d '\n'
# The Sheet must be shared with this account's client_email as an Editor.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}

# The Google Sheet to write to — the long ID in the sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=1AbC...xyz

# ── Optional override (safe to leave commented; sensible default applies) ──

# Apify actor that does the scraping. Default: compass/crawler-google-places
# APIFY_ACTOR_ID=compass/crawler-google-places
